# Claude API (obligatorio)
ANTHROPIC_API_KEY=sk-ant-...

# YouTube Data API v3 (opcional - desactiva la fuente si no lo defines)
# Obtener en https://console.cloud.google.com -> APIs & Services -> Credentials
YOUTUBE_API_KEY=

# Configuración por defecto (puede sobreescribirse por CLI)
DEFAULT_REGIONS=ES,MX,AR,CO,CL,PE
DEFAULT_TIMEFRAME=now 7-d
CLAUDE_MODEL=claude-opus-4-7
